# DriveSense environment variables
# Copy to .env and fill in values — NEVER commit .env to git

# Database
POSTGRES_USER=drivesense
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=drivesense
DATABASE_URL=postgresql://drivesense:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/drivesense

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:6379

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

# Server
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
LOG_LEVEL=info

# Frontend
FRONTEND_URL=http://localhost:5173

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.CHANGE_ME

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=DriveSense <noreply@example.com>
